<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>CareOps Clinic Suite</title>
  <link rel="stylesheet" href="/assets/app.css">
  <script src="/assets/htmx-lite.js" defer></script>
</head>
<body>
<main class="shell">
  <header class="hero">
    <div>
      <p class="kicker">CareOps Clinic Administration Suite</p>
      <h1>Server-Rendered Operations Console</h1>
      <p class="subtitle">HTMX-driven workflows for occupancy, quality checkpoints, alerts, scheduling, finance, and governance.</p>
    </div>
    <div class="session-chip">{{.Username}}</div>
  </header>
  <section class="panel">
    <div class="top-nav" onclick="var btns=this.querySelectorAll('button[hx-get]');btns.forEach(function(b){b.removeAttribute('data-active')});if(event.target.hasAttribute('hx-get'))event.target.setAttribute('data-active','1')">
      <button hx-get="/ui/panels/overview" hx-target="#panel" data-active="1">Overview</button>
      <button hx-get="/ui/panels/occupancy" hx-target="#panel">Occupancy</button>
      <button hx-get="/ui/panels/care" hx-target="#panel">Quality and Alerts</button>
      <button hx-get="/ui/panels/exercises" hx-target="#panel">Exercises</button>
      <button hx-get="/ui/panels/scheduling" hx-target="#panel">Scheduling</button>
      <button hx-get="/ui/panels/finance" hx-target="#panel">Finance</button>
      <button hx-get="/ui/panels/reports" hx-target="#panel">Reports and Audit</button>
      <form method="post" action="/logout" onsubmit="Object.keys(localStorage).filter(function(k){return k.startsWith('clinic:')}).forEach(function(k){localStorage.removeItem(k)})">
        <button type="submit" class="warn">Logout</button>
      </form>
    </div>
    <div id="htmx-indicator" class="hint" style="display:none">Loading...</div>
    <div id="panel" hx-get="/ui/panels/overview" hx-trigger="load" hx-target="#panel"></div>
  </section>
</main>
</body>
</html>

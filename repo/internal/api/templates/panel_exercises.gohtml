<section class="view active">
<article class="card"><h3>Exercise Discovery</h3><p class="hint">Search by keyword, filter by tags, difficulty, body part, contraindications, and coaching points.</p><form class="stack-form" hx-get="/ui/panels/exercises" hx-target="#panel"><div class="grid two"><label>Search<input name="q" value="{{.Query}}" placeholder="e.g. hamstring stretch"></label><label>Difficulty<select name="difficulty"><option value="">All</option><option value="beginner" {{if eq .Difficulty "beginner"}}selected{{end}}>Beginner</option><option value="intermediate" {{if eq .Difficulty "intermediate"}}selected{{end}}>Intermediate</option><option value="advanced" {{if eq .Difficulty "advanced"}}selected{{end}}>Advanced</option></select></label></div><div class="grid two"><label>Tags<input name="tags" value="{{.Tags}}" placeholder="e.g. balance, stretching"></label><label>Equipment<input name="equipment" value="{{.Equipment}}" placeholder="e.g. resistance_band"></label></div><div class="grid two"><label>Body Region<input name="body_region" value="{{.BodyRegion}}" placeholder="e.g. lower_back, hamstring"></label><label>Contraindications<input name="contraindications" value="{{.Contraindications}}" placeholder="e.g. acute_injury"></label></div><label>Coaching Points<input name="coaching_points" value="{{.CoachingPoints}}" placeholder="e.g. Keep spine neutral"></label><button type="submit">Search / Filter</button></form></article>
<article class="card"><h3>Add Exercise</h3><form class="stack-form" hx-post="/ui/exercises/create" hx-target="#panel"><label>Title<input name="title" required placeholder="e.g. Seated Hamstring Stretch"></label><label>Difficulty<select name="difficulty"><option value="beginner">Beginner</option><option value="intermediate">Intermediate</option><option value="advanced">Advanced</option></select></label><label>Body Region<input name="body_region" placeholder="e.g. lower_back, hamstring"></label><label>Contraindications<input name="contraindications" placeholder="e.g. acute_injury, post_surgery"></label><label>Coaching Points<input name="coaching_points" placeholder="e.g. Keep spine neutral, breathe steadily"></label><label>Description<textarea name="description" rows="2" placeholder="Detailed technique description..."></textarea></label><button type="submit">Create Exercise</button></form></article>
<article class="card"><h3>Exercise Library</h3><p class="hint">Click favorites to save for quick access. Cached content uses LRU policy (2 GB / 200 items).{{if .ActiveFilter}} Showing filtered results.{{end}}</p><div class="stack">{{if not .Items}}<p class="hint">No exercises found{{if .ActiveFilter}} matching your filters. Try broadening your search.{{else}}. Create one above.{{end}}</p>{{end}}{{range .Items}}<div class="exercise-row"><div><strong>{{.Title}}</strong><div>{{.Difficulty}}{{if .CoachingPoints}} &mdash; <em>{{.CoachingPoints}}</em>{{end}}</div>{{if .BodyRegions}}<div class="hint">Body: {{.BodyRegions}}</div>{{end}}{{if .Contraindications}}<div class="hint">Contraindications: {{.Contraindications}}</div>{{end}}</div><div><button hx-get="/ui/exercises/{{.ID}}" hx-target="#panel">View</button>{{if .MediaCount}}<span class="hint" title="{{.MediaCount}} media files attached">&#128247; {{.MediaCount}}</span>{{end}}<button class="{{if .Favored}}favorite{{end}}" hx-post="/ui/exercises/{{.ID}}/favorite" hx-target="#panel">{{if .Favored}}Favorited{{else}}Add Favorite{{end}}</button></div></div>{{end}}</div>
<h4>Upload Media</h4><form class="stack-form" enctype="multipart/form-data" hx-post="/ui/exercises/media/upload" hx-target="#panel"><div class="grid two"><label>Exercise ID<input type="number" name="exercise_id" required></label><label>Type<select name="media_type"><option value="image">Image</option><option value="video">Video</option><option value="document">Document</option></select></label></div><label>File<input type="file" name="file" required></label><button type="submit">Upload Media</button></form>
<div class="row"><button hx-get="/ui/cache/lru" hx-target="#cache-fragment">Load Cache Simulator</button><button class="warn" onclick="window.clearClinicDeviceCache()">Clear Device Cache</button></div><div id="cache-fragment" class="stack"></div></article></section>

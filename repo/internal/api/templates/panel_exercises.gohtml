<section class="view active">
<article class="card"><h3>Add Exercise</h3><form class="stack-form" hx-post="/ui/exercises/create" hx-target="#panel"><label>Title<input name="title" required placeholder="e.g. Seated Hamstring Stretch"></label><label>Difficulty<select name="difficulty"><option value="beginner">Beginner</option><option value="intermediate">Intermediate</option><option value="advanced">Advanced</option></select></label><label>Body Region<input name="body_region" placeholder="e.g. lower_back, hamstring"></label><label>Contraindications<input name="contraindications" placeholder="e.g. acute_injury, post_surgery"></label><label>Coaching Points<input name="coaching_points" placeholder="e.g. Keep spine neutral, breathe steadily"></label><label>Description<textarea name="description" rows="2" placeholder="Detailed technique description..."></textarea></label><button type="submit">Create Exercise</button></form></article>
<article class="card"><h3>Exercise Library</h3><p class="hint">Click favorites to save for quick access. Cached content uses LRU policy (2 GB / 200 items).</p><div class="stack">{{if not .Items}}<p class="hint">No exercises available. Create one above.</p>{{end}}{{range .Items}}<div class="exercise-row"><div><strong>{{.Title}}</strong><div>{{.Difficulty}}</div></div><button class="{{if .Favored}}favorite{{end}}" hx-post="/ui/exercises/{{.ID}}/favorite" hx-target="#panel">{{if .Favored}}Favorited{{else}}Add Favorite{{end}}</button></div>{{end}}</div><div class="row"><button hx-get="/ui/cache/lru" hx-target="#cache-fragment">Load Cache Simulator</button><button class="warn" onclick="window.clearClinicDeviceCache()">Clear Device Cache</button></div><div id="cache-fragment" class="stack"></div></article></section>

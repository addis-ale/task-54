<section class="view active"><article class="card"><h3>Exercise Browse and Favorites</h3><p class="hint">Server-rendered list with HTMX toggle actions.</p><div class="stack">{{if not .Items}}<p class="hint">No exercises available.</p>{{end}}{{range .Items}}<div class="exercise-row"><div><strong>{{.Title}}</strong><div>{{.Difficulty}}</div></div><button class="{{if .Favored}}favorite{{end}}" hx-post="/ui/exercises/{{.ID}}/favorite" hx-target="#panel">{{if .Favored}}Favorited{{else}}Add Favorite{{end}}</button></div>{{end}}</div><div class="row"><button hx-get="/ui/cache/lru" hx-target="#cache-fragment">Load Cache Simulator</button><button class="warn" onclick="window.clearClinicDeviceCache()">Clear Device Cache</button></div><div id="cache-fragment" class="stack"></div></article></section>
